<Application x:Class="FamilyTree.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:FamilyTree.App.Localization"
             xmlns:conv="clr-namespace:FamilyTree.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Тематичний словник (Theme.Light/Theme.Dark) додається у рантаймі через ThemeService. -->
                <ResourceDictionary Source="Styles/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <loc:LocalizeConverter x:Key="LocalizeConverter" />
            <conv:PersonYearsConverter x:Key="PersonYearsConverter" />

            <!-- Спільний шаблон пунктів комбобоксів: показує DisplayName (оновлюється живо). -->
            <DataTemplate x:Key="OptionDisplayTemplate">
                <TextBlock Text="{Binding DisplayName}" />
            </DataTemplate>

            <!-- Іконка застосунку: синій бейдж із гліфом родового дерева (три вузли). -->
            <DrawingImage x:Key="AppIcon">
                <DrawingImage.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#2E5D8A">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,48,48" RadiusX="10" RadiusY="10" />
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Pen>
                                <Pen Brush="White" Thickness="2.5" LineJoin="Round" />
                            </GeometryDrawing.Pen>
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <LineGeometry StartPoint="24,15" EndPoint="14,33" />
                                    <LineGeometry StartPoint="24,15" EndPoint="34,33" />
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="White">
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <EllipseGeometry Center="24,13" RadiusX="5.5" RadiusY="5.5" />
                                    <EllipseGeometry Center="13,35" RadiusX="5.5" RadiusY="5.5" />
                                    <EllipseGeometry Center="35,35" RadiusX="5.5" RadiusY="5.5" />
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingImage.Drawing>
            </DrawingImage>
            <conv:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
            <conv:DepthLabelConverter x:Key="DepthLabelConverter" />
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

            <!-- Іконки (viewBox 24) для кнопок дій -->
            <StreamGeometry x:Key="TrashGeometry">M6 7 H18 L16.8 21 H7.2 Z M4 5 H20 V6.8 H4 Z M9.5 3 H14.5 V4.8 H9.5 Z M9.5 9 H10.7 V19 H9.5 Z M13.3 9 H14.5 V19 H13.3 Z</StreamGeometry>
            <StreamGeometry x:Key="PencilGeometry">M4 20 L4 16 L14 6 L18 10 L8 20 Z M15 5 L17 3 L21 7 L19 9 Z</StreamGeometry>
        </ResourceDictionary>
    </Application.Resources>
</Application>
