<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- СВІТЛА тема. Набір ключів мусить збігатися з Theme.Dark.xaml. -->

    <SolidColorBrush x:Key="PrimaryBrush" Color="#2E5D8A" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#3A6FA3" />
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#244B70" />
    <SolidColorBrush x:Key="AccentBrush" Color="#4C9A6E" />

    <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F6F8" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BorderBrush" Color="#D4D8DE" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E2226" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5C636B" />
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF" />

    <SolidColorBrush x:Key="WarningBrush" Color="#C9922B" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#C0392B" />

</ResourceDictionary>
