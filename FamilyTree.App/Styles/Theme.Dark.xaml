<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ТЕМНА тема. Набір ключів мусить збігатися з Theme.Light.xaml. -->

    <SolidColorBrush x:Key="PrimaryBrush" Color="#4C8DC4" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#5C9BD1" />
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#3E7AAD" />
    <SolidColorBrush x:Key="AccentBrush" Color="#5FB183" />

    <SolidColorBrush x:Key="BackgroundBrush" Color="#1E2126" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#262A30" />
    <SolidColorBrush x:Key="BorderBrush" Color="#3A404A" />
    <SolidColorBrush x:Key="TreeEdgeBrush" Color="#7E8794" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E6E8EB" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9AA1AA" />
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF" />

    <SolidColorBrush x:Key="WarningBrush" Color="#E0A93E" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#E05B4C" />

</ResourceDictionary>
