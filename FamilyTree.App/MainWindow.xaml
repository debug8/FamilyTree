<Window x:Class="FamilyTree.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:FamilyTree.App.Localization"
        Title="{loc:Localize MainWindow_Title}"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <DockPanel>

        <!-- Верхня панель: перемикачі мови та теми -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                <TextBlock Text="{loc:Localize Settings_Language}"
                           Style="{StaticResource SecondaryTextStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                          ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding SelectedLanguage}"
                          DisplayMemberPath="DisplayName" />

                <TextBlock Text="{loc:Localize Settings_Theme}"
                           Style="{StaticResource SecondaryTextStyle}"
                           VerticalAlignment="Center"
                           Margin="20,0,8,0" />
                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                          MinWidth="120"
                          ItemsSource="{Binding AvailableThemes}"
                          SelectedItem="{Binding SelectedTheme}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NameKey, Converter={StaticResource LocalizeConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="{loc:Localize Settings_Naming}"
                           Style="{StaticResource SecondaryTextStyle}"
                           VerticalAlignment="Center"
                           Margin="20,0,8,0" />
                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                          MinWidth="170"
                          ItemsSource="{Binding AvailableNamingStyles}"
                          SelectedItem="{Binding SelectedNamingStyle}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NameKey, Converter={StaticResource LocalizeConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

            </StackPanel>
        </Border>

        <!-- Статус-бар -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource SurfaceBrush}">
            <StatusBarItem>
                <TextBlock Text="{loc:Localize StatusBar_NoFile}"
                           Style="{StaticResource SecondaryTextStyle}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Localize StatusBar_Today}"
                               Style="{StaticResource SecondaryTextStyle}"
                               Margin="0,0,6,0" />
                    <TextBlock Text="{Binding TodayFormatted}"
                               Style="{StaticResource SecondaryTextStyle}" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Центральна область -->
        <Grid>
            <TextBlock Text="{loc:Localize MainWindow_Welcome}"
                       Style="{StaticResource HeadingTextStyle}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

    </DockPanel>
</Window>
