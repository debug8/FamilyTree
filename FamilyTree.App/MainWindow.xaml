<Window x:Class="FamilyTree.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:FamilyTree.App.Localization"
        xmlns:controls="clr-namespace:FamilyTree.App.Controls"
        Title="{Binding Title}"
        Height="640" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewCommand}" />
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}" />
    </Window.InputBindings>
    <DockPanel>

        <!-- Меню Файл -->
        <Menu DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}">
            <MenuItem Header="{loc:Localize Menu_File}">
                <MenuItem Header="{loc:Localize Menu_New}" Command="{Binding NewCommand}" InputGestureText="Ctrl+N" />
                <MenuItem Header="{loc:Localize Menu_Open}" Command="{Binding OpenCommand}" InputGestureText="Ctrl+O" />
                <Separator />
                <MenuItem Header="{loc:Localize Menu_Save}" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S" />
                <MenuItem Header="{loc:Localize Menu_SaveAs}" Command="{Binding SaveAsCommand}" />
                <Separator />
                <MenuItem Header="{loc:Localize Menu_Recent}" ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="Command"
                                    Value="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=Menu}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator />
                <MenuItem Header="{loc:Localize Menu_Exit}" Command="{Binding ExitCommand}" />
            </MenuItem>
        </Menu>

        <!-- Верхня панель: перемикачі мови, теми, стилю назв -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="{loc:Localize Settings_Language}" Style="{StaticResource SecondaryTextStyle}"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                          ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding SelectedLanguage}"
                          DisplayMemberPath="DisplayName" />

                <TextBlock Text="{loc:Localize Settings_Theme}" Style="{StaticResource SecondaryTextStyle}"
                           VerticalAlignment="Center" Margin="20,0,8,0" />
                <ComboBox Style="{StaticResource InputComboBoxStyle}" MinWidth="120"
                          ItemsSource="{Binding AvailableThemes}" SelectedItem="{Binding SelectedTheme}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NameKey, Converter={StaticResource LocalizeConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="{loc:Localize Settings_Naming}" Style="{StaticResource SecondaryTextStyle}"
                           VerticalAlignment="Center" Margin="20,0,8,0" />
                <ComboBox Style="{StaticResource InputComboBoxStyle}" MinWidth="170"
                          ItemsSource="{Binding AvailableNamingStyles}" SelectedItem="{Binding SelectedNamingStyle}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NameKey, Converter={StaticResource LocalizeConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Статус-бар -->
        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding DocumentStatus}" Style="{StaticResource SecondaryTextStyle}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding PersonsCountText}" Style="{StaticResource SecondaryTextStyle}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{loc:Localize StatusBar_Today}" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding TodayFormatted}" Style="{StaticResource SecondaryTextStyle}" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Ліва панель: список осіб -->
        <Border DockPanel.Dock="Left" Width="320"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="12">
                <!-- Кнопки CRUD -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="{loc:Localize Common_Add}" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AddPersonCommand}" Margin="0,0,6,0" />
                    <Button Content="{loc:Localize Common_Edit}" Command="{Binding EditPersonCommand}" Margin="0,0,6,0" Padding="12,7" />
                    <Button Content="{loc:Localize Common_Delete}" Command="{Binding DeletePersonCommand}" Padding="12,7" />
                </StackPanel>

                <!-- Пошук -->
                <TextBox DockPanel.Dock="Top" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,8"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="{loc:Localize PersonList_SearchHint}" />

                <!-- Сортування -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Text="{loc:Localize Sort_Label}" DockPanel.Dock="Left"
                               Style="{StaticResource SecondaryTextStyle}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Button DockPanel.Dock="Right" Width="30" Height="30" Margin="6,0,0,0"
                            Command="{Binding ToggleSortDirectionCommand}"
                            Content="{Binding SortDirectionGlyph}" FontSize="14"
                            ToolTip="{loc:Localize Sort_Direction}" />
                    <ComboBox Style="{StaticResource InputComboBoxStyle}"
                              ItemsSource="{Binding AvailableSortOptions}" SelectedItem="{Binding SelectedSort}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding NameKey, Converter={StaticResource LocalizeConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </DockPanel>

                <!-- Список -->
                <ListBox ItemsSource="{Binding Persons}" SelectedItem="{Binding SelectedPerson}"
                         BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,4">
                                <TextBlock Text="{Binding FullName}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" />
                                <TextBlock Text="{Binding Converter={StaticResource PersonYearsConverter}}"
                                           Style="{StaticResource SecondaryTextStyle}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Центральна область: вкладки «Особа» та «Дерево» -->
        <TabControl Background="Transparent" BorderThickness="0">
        <TabItem Header="{loc:Localize Tab_Person}">
        <Grid>
            <TextBlock Text="{loc:Localize MainWindow_Welcome}"
                       Style="{StaticResource HeadingTextStyle}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding NoSelection, Converter={StaticResource BoolToVisibility}}" />

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasSelectedPerson, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Margin="24">
                    <TextBlock Text="{Binding SelectedPerson.FullName}" Style="{StaticResource HeadingTextStyle}" Margin="0,0,0,16" />

                    <!-- Батьки -->
                    <DockPanel Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right" Content="{loc:Localize Common_Add}"
                                Command="{Binding AddParentCommand}" Padding="10,4" />
                        <TextBlock Text="{loc:Localize Rel_Parents}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding Parents}" Margin="0,0,0,16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,2">
                                    <Button DockPanel.Dock="Right" Content="✕" Padding="6,0" MinWidth="24"
                                            Command="{Binding DataContext.RemoveParentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                    <TextBlock Text="{Binding FullName}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Діти -->
                    <DockPanel Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right" Content="{loc:Localize Common_Add}"
                                Command="{Binding AddChildCommand}" Padding="10,4" />
                        <TextBlock Text="{loc:Localize Rel_Children}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding Children}" Margin="0,0,0,16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,2">
                                    <Button DockPanel.Dock="Right" Content="✕" Padding="6,0" MinWidth="24"
                                            Command="{Binding DataContext.RemoveChildCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                    <TextBlock Text="{Binding FullName}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Подружжя -->
                    <DockPanel Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right" Content="{loc:Localize Common_Add}"
                                Command="{Binding AddSpouseCommand}" Padding="10,4" />
                        <TextBlock Text="{loc:Localize Rel_Spouses}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding Spouses}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,2">
                                    <Button DockPanel.Dock="Right" Content="✕" Padding="6,0" MinWidth="24"
                                            Command="{Binding DataContext.RemoveSpouseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                    <TextBlock Text="{Binding FullName}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        </TabItem>

        <TabItem Header="{loc:Localize Tab_Tree}">
            <controls:TreeCanvasControl DataContext="{Binding Tree}" />
        </TabItem>
        </TabControl>

    </DockPanel>
</Window>
