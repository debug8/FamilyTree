<Window x:Class="FamilyTree.App.PersonEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:FamilyTree.App.Localization"
        Title="{Binding TitleKey, Converter={StaticResource LocalizeConverter}}"
        Height="560" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="FieldLabel" BasedOn="{StaticResource SecondaryTextStyle}">
            <Setter Property="Margin" Value="0,10,0,3" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{loc:Localize Person_LastName}" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource InputTextBoxStyle}"
                         Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <TextBlock Text="{loc:Localize Person_FirstName}" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource InputTextBoxStyle}"
                         Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <TextBlock Text="{loc:Localize Person_MiddleName}" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource InputTextBoxStyle}"
                         Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="{loc:Localize Person_MaidenName}" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource InputTextBoxStyle}"
                         Text="{Binding MaidenName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="{loc:Localize Person_Gender}" Style="{StaticResource FieldLabel}" />
                <ComboBox Style="{StaticResource InputComboBoxStyle}"
                          HorizontalAlignment="Left" MinWidth="200"
                          ItemsSource="{Binding Genders}"
                          SelectedItem="{Binding SelectedGender, ValidatesOnNotifyDataErrors=True}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NameKey, Converter={StaticResource LocalizeConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="{loc:Localize Person_BirthDate}" Style="{StaticResource FieldLabel}" />
                <DatePicker SelectedDate="{Binding BirthDate}" HorizontalAlignment="Left" MinWidth="200" />

                <TextBlock Text="{loc:Localize Person_BirthPlace}" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource InputTextBoxStyle}"
                         Text="{Binding BirthPlace, UpdateSourceTrigger=PropertyChanged}" />

                <CheckBox Content="{loc:Localize Person_IsAlive}" IsChecked="{Binding IsAlive}"
                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,14,0,0" />

                <StackPanel Visibility="{Binding ShowDeathDate, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{loc:Localize Person_DeathDate}" Style="{StaticResource FieldLabel}" />
                    <DatePicker SelectedDate="{Binding DeathDate}" HorizontalAlignment="Left" MinWidth="200" />
                </StackPanel>

                <TextBlock Text="{loc:Localize Person_Notes}" Style="{StaticResource FieldLabel}" />
                <TextBox Style="{StaticResource InputTextBoxStyle}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                         Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{loc:Localize Common_Cancel}" MinWidth="90" Margin="0,0,10,0"
                    IsCancel="True" Click="Cancel_Click" />
            <Button Content="{loc:Localize Common_Save}" MinWidth="90"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsEnabled="{Binding CanSave}" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
