<UserControl x:Class="FamilyTree.App.Controls.TreeCanvasControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:FamilyTree.App.Localization">
    <DockPanel>
        <!-- Панель керування -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
            <TextBlock Text="{loc:Localize Tree_Mode}" Style="{StaticResource SecondaryTextStyle}"
                       VerticalAlignment="Center" Margin="0,0,6,0" />
            <ComboBox Style="{StaticResource InputComboBoxStyle}" MinWidth="120"
                      ItemsSource="{Binding AvailableModes}" SelectedItem="{Binding SelectedMode}"
                      ItemTemplate="{StaticResource OptionDisplayTemplate}" />

            <TextBlock Text="{loc:Localize Tree_Depth}" Style="{StaticResource SecondaryTextStyle}"
                       VerticalAlignment="Center" Margin="16,0,6,0" />
            <ComboBox Style="{StaticResource InputComboBoxStyle}" MinWidth="80"
                      ItemsSource="{Binding DepthOptions}" SelectedItem="{Binding Depth}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource DepthLabelConverter}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Button Content="{loc:Localize Tree_Fit}" Padding="10,4" Margin="16,0,6,0" Click="Fit_Click" />
            <Button Content="100%" Padding="10,4" Click="Reset_Click" />
        </StackPanel>

        <ScrollViewer x:Name="Scroller"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource BackgroundBrush}"
                      PreviewMouseWheel="Scroller_PreviewMouseWheel"
                      MouseRightButtonDown="Pan_Start" MouseRightButtonUp="Pan_End" MouseMove="Pan_Move">
            <Canvas x:Name="Scene" Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}"
                    HorizontalAlignment="Left" VerticalAlignment="Top">
                <Canvas.LayoutTransform>
                    <ScaleTransform x:Name="SceneScale" />
                </Canvas.LayoutTransform>

                <!-- Рамки подружжя (чинний шлюб) — позаду карток -->
                <ItemsControl ItemsSource="{Binding Couples}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="{Binding Width}" Height="{Binding Height}" CornerRadius="12"
                                    Background="#22D64545"
                                    BorderBrush="#D64545" BorderThickness="1.5" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Ребра -->
                <ItemsControl ItemsSource="{Binding Edges}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}"
                                  StrokeThickness="1.5">
                                <Line.Style>
                                    <Style TargetType="Line">
                                        <Setter Property="Stroke" Value="{DynamicResource BorderBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSpouse}" Value="True">
                                                <Setter Property="Stroke" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="StrokeDashArray" Value="3 2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Line.Style>
                            </Line>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Вузли -->
                <ItemsControl ItemsSource="{Binding Nodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="{Binding Width}" Height="{Binding Height}" CornerRadius="8"
                                    Background="{DynamicResource SurfaceBrush}" BorderThickness="1.5"
                                    MouseLeftButtonDown="Node_MouseLeftButtonDown" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRoot}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="BorderThickness" Value="2.5" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                <Setter Property="BorderThickness" Value="2.5" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Margin="10,8" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding RelationBadge}" FontSize="11"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               Visibility="{Binding RelationBadge, Converter={StaticResource NullToCollapsedConverter}}" />
                                    <TextBlock Text="{Binding FullName}" FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Years}" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Canvas>
        </ScrollViewer>
    </DockPanel>
</UserControl>
