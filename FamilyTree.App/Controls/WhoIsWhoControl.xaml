<UserControl x:Class="FamilyTree.App.Controls.WhoIsWhoControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:FamilyTree.App.Localization">
    <UserControl.Resources>
        <DataTemplate x:Key="PersonItemTemplate">
            <TextBlock Text="{Binding FullName}" />
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="{loc:Localize WhoIsWho_Person1}" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,3" />
            <ComboBox Style="{StaticResource InputComboBoxStyle}" MinWidth="260" HorizontalAlignment="Left"
                      ItemsSource="{Binding Persons}" SelectedItem="{Binding Person1}"
                      ItemTemplate="{StaticResource PersonItemTemplate}" />

            <TextBlock Text="{loc:Localize WhoIsWho_Person2}" Style="{StaticResource SecondaryTextStyle}" Margin="0,14,0,3" />
            <ComboBox Style="{StaticResource InputComboBoxStyle}" MinWidth="260" HorizontalAlignment="Left"
                      ItemsSource="{Binding Persons}" SelectedItem="{Binding Person2}"
                      ItemTemplate="{StaticResource PersonItemTemplate}" />

            <!-- Результат -->
            <Border Margin="0,20,0,0" Padding="16" CornerRadius="8"
                    Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{Binding ResultSummary}" Style="{StaticResource HeadingTextStyle}"
                               TextWrapping="Wrap" />

                    <TextBlock Text="{loc:Localize WhoIsWho_Path}" Style="{StaticResource SecondaryTextStyle}"
                               Margin="0,14,0,4" FontWeight="SemiBold" />
                    <ItemsControl ItemsSource="{Binding Steps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Margin="0,2"
                                           Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <TextBlock Text="{loc:Localize WhoIsWho_Hint}" Style="{StaticResource SecondaryTextStyle}"
                       Margin="0,16,0,0" TextWrapping="Wrap"
                       Visibility="{Binding NoResult, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
